{
  "name": "bolhatech-design-system",
  "version": "0.2.1",
  "description": "Design system React do ecossistema AbolhaTech — visual limpo, Inter, sem glassmorphism.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "client.js",
    "client.cjs",
    "dist",
    "src/styles.css",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./client.js",
      "require": "./client.cjs"
    },
    "./styles.css": "./src/styles.css",
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    }
  },
  "sideEffects": [
    "./src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build-storybook": "HOME=./.storybook-home storybook build",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "storybook": "HOME=./.storybook-home storybook dev -p 6006 --host 127.0.0.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.18",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  }
}
